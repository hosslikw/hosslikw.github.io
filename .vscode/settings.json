{
    "[css]": {
		"editor.defaultFormatter": "stylelint.vscode-stylelint"
	},
    "codeium.enableExplainProblem": true,
    "codeium.enableInComments": true,

	// Enables or disables all validations.
	"css.validate": true,
	"cssPeek.enable": true,
	"cssPeek.peekFromLanguages": [
		"html",
		"django-html",
		"laravel-blade",
		"razor",
		"vue",
		"blade",
		"pug",
		"jade",
		"handlebars",
		"php",
		"twig",
		"md",
		"nunjucks",
		"javascript",
		"javascriptreact",
		"erb",
		"typescript",
		"typescriptreact",
		"HTML (Eex)",
		"html-eex",
		"ejs",
		"hbs",
		"svelte"
	],

	// A list of file globs that filters out peekable files
	"cssPeek.peekToExclude": ["**/node_modules/**"],
	"cssPeek.supportTags": true,
    "css.completion.completePropertyWithSemicolon": false,
    "css.format.braceStyle": "collapse",
    "css.format.enable": true,
    "css.lint.important": "warning",
    "css.lint.unknownAtRules": "warning",
    "css.lint.unknownProperties": "warning",
    "css.lint.hexColorLength": "error",
    "css.lint.fontFaceProperties": "warning",
    "css.lint.emptyRules": "warning",
    "css.lint.duplicateProperties": "warning",
    "css.lint.compatibleVendorPrefixes": "warning",
    "css.hover.references": true,
    "css.hover.documentation": true,
    "css.format.preserveNewLines": false,
    "css.format.newlineBetweenRules": true,
    "css.format.newlineBetweenSelectors": false,
    "css.lint.unknownVendorSpecificProperties": "warning",
    "css.lint.vendorPrefix": "warning",
    "css.validate": true,
    "html.autoClosingTags": false,
	"html.autoCreateQuotes": false,
	"html.format.enable": true,
	"html.format.contentUnformatted": "pre,code,textarea",
	"html.format.extraLiners": "none",
	"html.format.indentHandlebars": false,
	"html.format.maxPreserveNewLines": 1,
	"html.format.indentInnerHtml": false,
	"html.format.preserveNewLines": false,
	"html.format.templating": false,
	"html.format.unformattedContentDelimiter": "Kyle Hossli",
	"html.format.wrapAttributes": "auto",
	"html.format.wrapLineLength": 120,
	"html.format.wrapAttributesIndentSize": null,
	"html.hover.documentation": true,
    "html.completion.attributeDefaultValue": "doublequotes",
    "html.format.maxPreserveNewLines": 1,
	"html.hover.references": true,
	"html.suggest.html5": true,
	"html.validate.scripts": true,
	"html.validate.styles": true,
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
    "prettier.arrowParens": "always",
    "prettier.bracketSpacing": true,
    "prettier.bracketSameLine": true,
    "prettier.endOfLine": "lf",
    "prettier.embeddedLanguageFormatting": "off",
    "prettier.enable": true,
    "prettier.enableDebugLogs": true,
    "prettier.htmlWhitespaceSensitivity": "ignore",
    "prettier.packageManager": "npm",
    "prettier.ignorePath": "/Users/Kyle/Sites/hosslikw.github.io/src/.prettierignore",
    "prettier.jsxBracketSameLine": true,
    "prettier.jsxSingleQuote": true,
    "prettier.printWidth": 120,
    "prettier.proseWrap": "always",
    "prettier.requirePragma": true,
    "prettier.semi": true,
    "prettier.singleQuote": true,
    "prettier.tabWidth": 4,
    "prettier.useTabs": true,
    "prettier.resolveGlobalModules": true,
    "prettier.insertPragma": true,
    "prettier.quoteProps": "consistent",
    "prettier.useEditorConfig": false,
    "macColorPicker.lowercaseHexColors": true,
    "npm.autoDetect": "on",
    "npm.enableRunFromFolder": true,
    "npm.enableScriptExplorer": true,
    "npm.packageManager": "npm",
    "references.preferredLocation": "view",
    "scss.completion.completePropertyWithSemicolon": true,
    "scss.format.braceStyle": "collapse",
    "scss.format.enable": true,
    "scss.format.newlineBetweenRules": true,
    "scss.format.preserveNewLines": false,
    "scss.format.newlineBetweenSelectors": false,
    "scss.hover.documentation": true,
    "scss.hover.references": true,
    "scss.lint.compatibleVendorPrefixes": "warning",
    "scss.lint.duplicateProperties": "warning",
    "scss.lint.emptyRules": "warning",
    "scss.lint.fontFaceProperties": "warning",
    "scss.lint.hexColorLength": "error",
    "scss.lint.propertyIgnoredDueToDisplay": "warning",
    "scss.lint.unknownAtRules": "warning",
    "scss.lint.unknownProperties": "warning",
    "scss.lint.unknownVendorSpecificProperties": "warning",
    "scss.lint.vendorPrefix": "warning",
    "scss.validate": true,
    "stylelint.configBasedir": "/Users/Kyle/Sites/hosslikw.github.io",
    "stylelint.snippet": [
        "css",
        "less",
        "postcss",
        "scss"
    ],
    "prettier.resolveGlobalModules": true,
	/*sass*/
	"sass.format.setPropertySpace": true,
	"sass.format.enabled": true,
	"sass.format.deleteWhitespace": true,
	"sass.format.deleteEmptyRows": true,
	"sass.format.debug": true,
	"sass.format.convert": true,

	/* #stylelint   */
	"stylelint.enable": true,
	"stylelint.validate": ["css", "less", "postcss", "scss"],
	"stylelint.codeAction.disableRuleComment": {
		"location": "separateLine"
	},
}