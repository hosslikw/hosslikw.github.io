{
	"[css]": {
		"editor.defaultFormatter": "stylelint.vscode-stylelint"
	},
	"codeium.enableExplainProblem": true,
	"codeium.enableInComments": true,
	// Enables or disables all validations.
	"css.validate": false,
	"cssPeek.supportTags": true,
	"cssPeek.peekFromLanguages": [
