{
  "extends": ["web-recommended"],
  "formatters": ["html"],
  "hints": {
    "button-type": "error",
    "compat-api/css": "warning",
    "compat-api/html": "warning",
    "create-element-svg": "error",
    "css-prefix-order": "warning",
    "detect-css-reflows/composite": "error",
    "detect-css-reflows/layout": "error",
    "detect-css-reflows/paint": "error",
    "disown-opener": "error",
    "highest-available-document-mode": "warning",
    "leading-dot-classlist": "error",
    "manifest-exists": "error",
    "meta-charset-utf-8": "error",
    "meta-viewport": "error",
    "no-bom": "error",
    "no-inline-styles": "warning",
    "no-protocol-relative-urls": "warning",
    "scoped-svg-styles": "error",
    "sri": "error"
  },
  "hintsTimeout": 5000
}