{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["jsconfig.json"]
    },
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["esnext", "dom"]
  }
}
