{
  "name": "webdev-portfolio",
  "description": "A web development portfolio built with a Vite multipage",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --open",
    "preview": "vite preview",
    "lint-html": "htmlhint ./src/*.html --config ./.htmlhintrc",
    "lint-css": "stylelint ./src/*.css --formatter verbose --config ./.stylelintrc.json --fix",
    "lint-js": "eslint . --fix --ignore-path .eslintignore",
    "format": "prettier --write './src/**/*.css' --config .prettierrc.json --ignore-path /.prettierignore",
    "postcss": "postcss './src/index.css' --output './src/main.css'",
    "wind": "tailwindcss -i './src/main.css' -o 'dist/output.css' --watch",
    "cypress-e2e": "start-server-and-test 'vite dev --port 4174' http://localhost:4174 'cypress open --e2e'",
    "vi-test": "vitest",
    "vi-e2e": "vitest run --config vitest.config.e2e.js --ui",
    "purgecss": "purgecss --config ./purge.config.js --output build/styles.css",
    "test-purge": "jest",
    "build-only": "vite build",
    "build": "cross-env NODE_ENV=production &&  build-only"
  },
  "devDependencies": {
    "@babel/core": "^7.4.3",
    "@babel/eslint-parser": "^7.24.1",
    "@babel/eslint-plugin": "^7.23.5",
    "@babel/preset-env": "^7.4.3",
    "@eslint/js": "^9.0.0",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@isnotdefined/stylelint-plugin": "^5.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rushstack/eslint-patch": "^1.10.0",
    "@swup/a11y-plugin": "^4.5.0",
    "@swup/body-class-plugin": "^3.2.0",
    "@swup/head-plugin": "^2.2.0",
    "@vitejs/plugin-legacy": "^5.3.2",
    "@vitest/ui": "^1.4.0",
    "browserslist": "^4.23.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cross-env": "^7.0.3",
    "cypress": "^13.7.1",
    "cypress-vite": "^1.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-formatter-pretty": "^6.0.1",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-html": "^8.1.0",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-jsonc": "^2.15.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "figlet": "^1.7.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "js-beautify": "^1.15.1",
    "jsdom": "^24.0.0",
    "lodash.merge": "^4.6.2",
    "npm-run-all2": "^6.1.2",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-html": "^1.5.0",
    "postcss-import": "^16.1.0",
    "postcss-modules": "^6.0.0",
    "postcss-nesting": "^12.1.0",
    "postcss-ordered-values": "^6.0.2",
    "postcss-preset-env": "^9.5.2",
    "postcss-safe-parser": "^7.0.0",
    "postcss-sorting": "^8.0.2",
    "postcss-value-parser": "^4.2.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-color-format": "^1.1.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^2.8.0",
    "stylelint-order": "^6.0.4",
    "stylelint-plugin-defensive-css": "^1.0.3",
    "stylelint-selector-bem-pattern": "^4.0.0",
    "swup": "^4.6.1",
    "vite": "^5.2.6",
    "vitest": "^1.4.0"
  }
}
