{
	"name": "webdev-portfolio",
	"description": "A web development portfolio built with a Vite multipage setup, utilizing Vue for components, Stylint, HTMLhint, and Eslint for linting, PostCSS and jsbeautify for formatting, and Cypress for testing. Visit: https://kylehossli.com",
	"license": "MIT",
	"private": true,
	"type": "module",
	"dependencies": {
		"@headlessui/vue": "^1.7.19",
		"@heroicons/vue": "^2.1.1",
		"@vueuse/core": "^10.7.2",
		"figlet": "^1.7.0",
		"vue": "^3.4.19",
		"vue-router": "^4.2.5"
	},
	"devDependencies": {
		"@fullhuman/postcss-purgecss": "^5.0.0",
		"@isnotdefined/stylelint-plugin": "^4.0.0",
		"@rollup/plugin-node-resolve": "^15.2.3",
		"@rushstack/eslint-patch": "^1.7.0",
		"@vitejs/plugin-legacy": "^5.2.0",
		"@vitejs/plugin-vue": "^5.0.3",
		"@vitejs/plugin-vue-jsx": "^3.1.0",
		"@vitest/ui": "^1.2.2",
		"@vue/compiler-sfc": "^3.4.19",
		"@vue/test-utils": "^2.4.3",
		"autoprefixer": "^10.4.17",
		"browserslist": "^4.23.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.0",
		"cross-env": "^7.0.3",
		"cssnano": "^6.0.2",
		"cssnano-preset-advanced": "^6.0.3",
		"cypress": "^13.6.1",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-cypress": "^2.15.1",
		"eslint-plugin-vue": "^9.21.1",
		"htmlhint": "^1.1.4",
		"js-beautify": "^1.15.1",
		"jsdom": "^24.0.0",
		"npm-run-all2": "^6.1.1",
		"postcss": "^8.4.33",
		"postcss-cli": "^11.0.0",
		"postcss-import": "^16.0.1",
		"postcss-modules": "^6.0.0",
		"postcss-nesting": "^12.0.2",
		"postcss-ordered-values": "^6.0.1",
		"postcss-preset-env": "^9.3.0",
		"postcss-sorting": "^8.0.2",
		"postcss-value-parser": "^4.2.0",
		"prettier": "^3.2.4",
		"rollup": "^4.12.0",
		"rollup-plugin-license": "^3.2.0",
		"start-server-and-test": "^2.0.3",
		"stylelint": "^16.1.0",
		"stylelint-color-format": "^1.1.0",
		"stylelint-config-idiomatic-order": "^10.0.0",
		"stylelint-config-recommended": "^14.0.0",
		"stylelint-config-standard": "^36.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^2.8.0",
		"stylelint-order": "^6.0.4",
		"stylelint-plugin-defensive-css": "^1.0.1",
		"stylelint-selector-bem-pattern": "^3.0.1",
		"tailwind-merge": "^2.2.0",
		"tailwindcss": "^3.4.1",
		"tailwindcss-animate": "^1.0.7",
		"tw-elements": "^1.1.0",
		"vite": "^5.1.3",
		"vite-plugin-vue-component-preview": "^1.1.6",
		"vitest": "^1.3.0"
	},
	"scripts": {
		"dev": "cross-env NODE_ENV=development vite --open",
		"preview": "vite preview",
		"linthtml": "htmlhint ./nested/**/*.html --config .htmlhintrc",
		"lintcss": "stylelint ./src/**/*.css --formatter verbose --config ./.stylelintrc.json --fix",
		"lintjs": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path ./.eslintignore",
		"format": "prettier --write 'src/*.css' 'nested/**/*.html' 'src/*.js' '*.json' --config .prettierrc.json --ignore-path .prettierignore",
		"formatjs": "find src -name '*.js' | xargs -n1 npx js-beautify -r --indent-size 4 --indent-char ' ' --max-preserve-newlines 2 --preserve-newlines --keep-array-indentation --break-chained-methods --indent-scripts normal --brace-style end-expand,preserve-inline --space-before-conditional --jslint-happy --end-with-newline --wrap-line-length 160 --indent-inner-html --comma-first --e4x --indent-empty-lines --unescape_strings",
		"lintandformat": "npm run format && npm run lintcss && npm run linthtml && npm run lintjs",
		"postessentials":"postcss src/collect.css --o essentials",
		"postcss": "postcss src/staging/main.css  --o index.css",
		"wind": "tailwindcss -i src/input.css -o dist/output.css --watch",
		"cypress-e2e": "start-server-and-test 'vite dev --port 4174' http://localhost:4174 'cypress open --e2e'",
		"vi-test": "vitest",
		"vi-e2e": "vitest run --config vitest.config.e2e.js --ui",
		"purgecss": "node purgecss.config.mjs",
		"build-only": "vite build",
		"build": "cross-env NODE_ENV=production &&  build-only"
	}
}
