{
  "name": "webdev-portfolio",
  "description": "A web development portfolio built with a Vite multipage",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --open",
    "preview": "vite preview --open",
    "lint-html": "htmlhint --config .htmlhintrc ./src/**/*.html",
    "lint-css": "stylelint ./src/**/*.css --formatter verbose --config ./stylelint.config.mjs --fix",
    "stylelint-find-rules": "stylelint-find-new-rules",
    "lint-js": "npx eslint . --fix",
    "format": "prettier --write './src/**/*.css''./**/*.json' --config .prettierrc.json --ignore-path ./.prettierignore",
    "postcss": "postcss './src/css/index.css' --output './src/css/main.css'",
    "cypress-e2e": "start-server-and-test 'vite dev --port 4174' http://localhost:4174 'cypress open --e2e'",
    "vi-test": "vitest",
    "vi-e2e": "vitest run --config vitest.config.e2e.js --ui",
    "purgecss": "purgecss --config ./purge.config.js --output build/styles.css",
    "test-purge": "jest",
    "build": "vite build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.2.0",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@isnotdefined/stylelint-plugin": "^5.0.0",
    "@rollup/plugin-eslint": "^9.0.5",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rushstack/eslint-patch": "^1.10.2",
    "@swup/a11y-plugin": "^5.0.0",
    "@swup/body-class-plugin": "^3.2.0",
    "@swup/head-plugin": "^2.2.0",
    "@vitejs/plugin-legacy": "^5.4.0",
    "@vitest/ui": "^1.6.0",
    "browserslist": "^4.23.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.1",
    "cypress": "^13.9.0",
    "cypress-vite": "^1.5.0",
    "eslint": "^9.2.0",
    "eslint-plugin-airbnb": "^0.0.1-security",
    "eslint-plugin-html": "^8.1.1",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^15.6.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jsdom": "^24.0.0",
    "lodash.merge": "^4.6.2",
    "npm-run-all2": "^6.1.2",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-html": "^1.7.0",
    "postcss-import": "^16.1.0",
    "postcss-modules": "^6.0.0",
    "postcss-nesting": "^12.1.4",
    "postcss-ordered-values": "^7.0.0",
    "postcss-preset-env": "^9.5.13",
    "postcss-safe-parser": "^7.0.0",
    "postcss-sorting": "^8.0.2",
    "postcss-value-parser": "^4.2.0",
    "prettier": "^3.2.5",
    "purgecss": "^6.0.0",
    "stylelint": "^16.5.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^2.8.0",
    "stylelint-find-new-rules": "^5.0.0",
    "stylelint-plugin-defensive-css": "^1.0.4",
    "swup": "^4.6.1",
    "vite": "^5.2.11",
    "vite-imagetools": "^7.0.2",
    "vite-plugin-deadfile": "^1.2.5",
    "vitest": "^1.6.0"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ]
}
