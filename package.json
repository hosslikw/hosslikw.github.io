{
	"dependencies": {
		"@formatjs/icu-messageformat-parser": "^2.7.3",
		"@isnotdefined/stylelint-plugin": "^4.0.0",
		"@radix-icons/vue": "^1.0.0",
		"@sentry/browser": "^7.92.0",
		"browserslist": "^4.22.2",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.0",
		"color": "^4.2.3",
		"hint": "^7.1.10",
		"postcss-values-parser": "^6.0.2",
		"radix-vue": "^1.2.5",
		"tailwind-merge": "^2.2.0",
		"tailwindcss-animate": "^1.0.7",
		"vue": "^3.3.11",
		"vue-router": "^4.2.5"
	},
	"devDependencies": {
		"@lhci/cli": "^0.13.0",
		"@rushstack/eslint-patch": "^1.3.3",
		"@tsconfig/node18": "^18.2.2",
		"@types/jsdom": "^21.1.6",
		"@types/node": "^20.10.6",
		"@vitejs/plugin-vue": "^5.0.2",
		"@vitejs/plugin-vue-jsx": "^3.1.0",
		"@vue/eslint-config-prettier": "^9.0.0",
		"@vue/eslint-config-typescript": "^12.0.0",
		"@vue/test-utils": "^2.4.3",
		"@vue/tsconfig": "^0.5.0",
		"autoprefixer": "^10.4.16",
		"cssnano": "^6.0.2",
		"cypress": "^13.6.1",
		"eslint": "^8.49.0",
		"eslint-plugin-cypress": "^2.15.1",
		"eslint-plugin-vue": "^9.17.0",
		"htmlhint": "^1.1.4",
		"js-beautify": "^1.14.11",
		"jsdom": "^23.0.1",
		"npm-run-all2": "^6.1.1",
		"postcss": "^8.4.33",
		"postcss-cli": "^11.0.0",
		"postcss-font-family-system-ui": "^5.0.0",
		"postcss-import": "^16.0.0",
		"postcss-modules": "^6.0.0",
		"postcss-nested": "^6.0.1",
		"postcss-preset-env": "^9.3.0",
		"prettier": "^3.1.1",
		"start-server-and-test": "^2.0.3",
		"stylelint": "^16.1.0",
		"stylelint-color-format": "^1.1.0",
		"stylelint-config-idiomatic-order": "^10.0.0",
		"stylelint-config-recommended": "^14.0.0",
		"stylelint-config-standard": "^36.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^2.8.0",
		"stylelint-order": "^6.0.4",
		"stylelint-plugin-defensive-css": "^1.0.0",
		"tailwindcss": "^3.4.1",
		"vite": "^5.0.11",
		"vitest": "^1.1.3",
		"vue-tsc": "^1.8.25"
	},
	"name": "webdev-portfolio",
	"private": true,
	"requires": true,
	"scripts": {
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "vite build",
		"dev": "vite",
		"post": "postcss src/Unprocessed-css/input.css -o dist/output.css --watch",
		"preview": "vite preview",
		"start": "serve dist",
		"eslint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore --debug",
		"html": "htmlhint **/*.html --config .htmlhintrc",
		"csslint": "stylelint 'src/Unprocessed-css/**/*.css' --formatter verbose --config ./.stylelintrc.json --fix",
		"format": "prettier --write '**/*' '!node_modules/**/*'",
		"style": "npm run format && npm run csslint && npm run html",
		"test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
		"test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
		"test:unit": "vitest",
		"type-check": "vue-tsc --build --force",
		"webhint": "hint http://localhost:8080"
	},
	"type": "module",
	"version": "0.0.0",
	"browserslist": "defaults"
}
