  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --open",
    "preview": "vite preview",
    "linthtml": "htmlhint ./*.html --config ./.htmlhintrc",
    "lintcss": "stylelint ./*.css --formatter verbose --config ./.stylelintrc.json --fix",
    "lint": "eslint . --fix --ignore-path .eslintignore",
    "format": "prettier --write './**/*.css' './**/*.html' './**/*.js' './**/*.json' --config .prettierrc.json --ignore-path .prettierignore",
    "formatjs": "find src -name '*.js' | xargs -n1 npx js-beautify -r --indent-size 4 --indent-char ' ' --max-preserve-newlines 2 --preserve-newlines --keep-array-indentation --break-chained-methods --indent-scripts normal --brace-style end-expand,preserve-inline --space-before-conditional --jslint-happy --end-with-newline --wrap-line-length 160 --indent-inner-html --comma-first --e4x --indent-empty-lines --unescape_strings",
    "lintandformat": "npm run format && npm run lintcss && npm run linthtml && npm run lintjs.css",
    "postcss": "postcss './index.css' --output './main.css'",
    "wind": "tailwindcss -i './main.css' -o 'dist/output.css' --watch",
    "cypress-e2e": "start-server-and-test 'vite dev --port 4174' http://localhost:4174 'cypress open --e2e'",
    "vi-test": "vitest",
    "vi-e2e": "vitest run --config vitest.config.e2e.js --ui",
    "purgecss": "node purgecss.config.mjs",
    "build-only": "vite build",
    "build": "cross-env NODE_ENV=production &&  build-only"
  }
