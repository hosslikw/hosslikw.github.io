{
	"name": "hosslikw.github.io",
	"version": "1.0.0",
	"description": "This is a static website that displays artwork and links to usable tools for makers. The repository can be used as a template for those who similarly want to display their content online.",
	"main": "dist/index.html",
	"scripts": {
		"lint": "htmlhint 'dist/**/*.html' && jest && stylelint 'dist/**/*.css'",
		"eslint": "eslint 'src/**/*{js,jsx,ts,tsx}' --fix",
		"format-css": "prettier --write 'dist/**/*.css'",
		"format-html": "prettier --write 'dist/**/*.html'",
		"dev": "vite --config src/vite.config.js",
		"preview": "vite preview --config src/vite.config.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yourusername/hosslikw.github.io"
	},
	"keywords": [
		"website",
		"portfolio",
		"template",
		"node.js",
		"bootstrap",
		"gulp",
		"github",
		"craft-app",
		"educators",
		"students",
		"artists",
		"beginners",
		"web-development",
		"self-promotion",
		"industry-employers",
		"university",
		"sculptures",
		"art",
		"free-content",
		"shortcuts",
		"scripts",
		"technology-tutorials",
		"sculpture-tutorials",
		"html",
		"css",
		"javascript",
		"accessibility",
		"responsive-design",
		"skill-display",
		"svg",
		"apple-shortcuts",
		"highlight-css",
		"sculpture",
		"education"
	],
	"author": "Kyle Hossli",
	"license": "MIT",
	"devDependencies": {
		"@babel/core": "^7.23.5",
		"@babel/preset-env": "^7.23.5",
		"@typescript-eslint/eslint-plugin": "^6.13.1",
		"eslint": "^8.55.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-config-standard-with-typescript": "^40.0.0",
		"eslint-plugin-import": "^2.29.0",
		"eslint-plugin-n": "^16.3.1",
		"eslint-plugin-prettier": "^5.0.1",
		"eslint-plugin-promise": "^6.1.1",
		"htmlhint": "^1.1.4",
		"prettier": "^3.1.0",
		"sass": "^1.69.5",
		"stylelint": "^15.11.0",
		"typescript": "^5.3.2",
		"vite": "^5.0.0",
		"vite-plugin-pug": "^0.3.2"
	},
	"dependencies": {
		"chokidar": "^3.5.3",
		"fsevents": "^2.3.3",
		"jquery": "^3.7.1"
	}
}
