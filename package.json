		"vue-tsc": "^1.8.27",
		"pinia": "^2.1.7"
	},
	"scripts": {
		"debug-serve": "VITE_DEBUG_SERVE=1 vitest run -c vitest.config.e2e.ts",
      "debug-build": "VITE_TEST_BUILD=1 VITE_PRESERVE_BUILD_ARTIFACTS=1 vitest run -c vitest.config.e2e.ts",
		"cypress": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
		"vitest": "VITE_TEST_BUILD=1 vitest run -c vitest.config.e2e.ts",
		"test-serve": "vitest run -c vitest.config.e2e.ts",
		"typecheck": "tsc -p scripts --noEmit && tsc -p playground --noEmit",
		"build": "cross-env NODE_ENV=production vite build && npm run purgecss",
		"purgecss": "node purgecss.config.mjs",
		"postcss": "postcss src/input.css -o dist/-output.css --watch",
		"lintandformat": "npm run format && npm run csslint && npm run html",
		"format": "prettier --write '**/*' '!node_modules/**/*' --config ./.prettierrc.json --ignore-path .prettierignore --debug",
		"lintjs": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore",
		"lintcss": "stylelint **/*.css --formatter verbose --config ./.stylelintrc.json --fix",
		"linthtml": "htmlhint **/*.html --config .htmlhintrc",
		"dev": "cross-env NODE_ENV=development vite"
	}
}
