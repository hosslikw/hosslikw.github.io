{
	"name": "webdev-portfolio",
	"description": "build environment Vite-Vue-Tailwind configs for Stylint, HTMLhint, eslint, PostCSS, Typescript, Cypress",
	"homepage": "https://kylehossli.com",
	"license": "MIT",
	"private": true,
	"type": "module",
	"dependencies": {
		"tailwind-merge": "^2.2.0",
		"tailwindcss": "^3.4.1",
		"tailwindcss-animate": "^1.0.7",
		"the-answer": "^1.0.0",
		"vue": "^3.4.15",
		"vue-router": "^4.2.5"
	},
	"devDependencies": {
		"@fullhuman/postcss-purgecss": "^5.0.0",
		"@isnotdefined/stylelint-plugin": "^4.0.0",
		"@rushstack/eslint-patch": "^1.7.0",
		"@tsconfig/node21": "^21.0.1",
		"@types/jsdom": "^21.1.6",
		"@types/node": "^20.11.5",
		"@types/resolve": "^1.20.6",
		"@typescript-eslint/eslint-plugin": "^6.19.0",
		"@typescript-eslint/parser": "^6.19.0",
		"@vitejs/plugin-legacy": "^5.2.0",
		"@vitejs/plugin-vue": "^5.0.3",
		"@vitejs/plugin-vue-jsx": "^3.1.0",
		"@vue/eslint-config-prettier": "^9.0.0",
		"@vue/eslint-config-typescript": "^12.0.0",
		"@vue/test-utils": "^2.4.3",
		"@vue/tsconfig": "^0.5.1",
		"@sentry/browser": "^7.93.0",
		"autoprefixer": "^10.4.17",
		"browserslist": "^4.22.2",
		"class-variance-authority": "^0.7.0",
		"cross-env": "^7.0.3",
		"clsx": "^2.1.0",
		"cssnano": "^6.0.2",
		"cssnano-preset-advanced": "^6.0.3",
		"cypress": "^13.6.1",
		"eslint": "^8.56.0",
		"eslint-plugin-cypress": "^2.15.1",
		"eslint-plugin-vue": "^9.20.1",
		"htmlhint": "^1.1.4",
		"js-beautify": "^1.14.11",
		"jsdom": "^23.2.0",
		"npm-run-all2": "^6.1.1",
		"pinia": "^2.1.7",
		"postcss": "^8.4.33",
		"postcss-value-parser": "^4.2.0",
		"postcss-cli": "^11.0.0",
		"postcss-import": "^16.0.0",
		"postcss-modules": "^6.0.0",
		"postcss-nesting": "^12.0.2",
		"postcss-preset-env": "^9.3.0",
		"prettier": "^3.2.4",
		"rollup": "^4.9.5",
		"rollup-plugin-license": "^3.2.0",
		"start-server-and-test": "^2.0.3",
		"stylelint": "^16.1.0",
		"stylelint-color-format": "^1.1.0",
		"stylelint-config-idiomatic-order": "^10.0.0",
		"stylelint-config-recommended": "^14.0.0",
		"stylelint-config-standard": "^36.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^2.8.0",
		"stylelint-order": "^6.0.4",
		"stylelint-plugin-defensive-css": "^1.0.1",
		"stylelint-selector-bem-pattern": "^3.0.1",
		"typescript": "^5.3.3",
		"vite": "^5.0.11",
		"vitest": "^1.2.1",
		"vue-tsc": "^1.8.27"
	},
	"scripts": {
		"test:unit": "vitest",
		"test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
		"test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
		"build-only": "vite build",

		"build": "cross-env NODE_ENV=production && run-s type-check build-only",
		"type-check": "vue-tsc --build --force",
		"wind": "tailwindcss -i @/input.css -o @/dist/output.css --watch",
		"purgecss": "node purgecss.config.mjs",
		"postcss": "postcss @/reset.css -o @/input.css --watch",
		"lintandformat": "npm run format && npm run csslint && npm run html",
		"format": "prettier --write \"@/**/*\" \"!@/node_modules/**/*\" --config @/.prettierrc.json --ignore-path @/.prettierignore",
		"lintjs": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path @/.eslintignore",
		"lintcss": "stylelint @/**/*.css --formatter verbose --config @/.stylelintrc.json --fix",
		"linthtml": "htmlhint @/**/*.html --config @/.htmlhintrc",
		"dev": "cross-env NODE_ENV=development vite --open",
		"preview": "vite preview"
	}
}
