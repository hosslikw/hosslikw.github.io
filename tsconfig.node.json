{
	"extends": "@tsconfig/node21/tsconfig.json",
	"include": ["vite.config.*", "vitest.config.*", "cypress.config.*", "nightwatch.conf.*", "playwright.config.*"],

	"compilerOptions": {
		"composite": true,
		"noEmit": true,

		"skipLibCheck": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"types": ["node"]
	}
}
