{
  "title-require": true,
  "html-lang-require": true,
  "doctype-first": true,
  "doctype-html5": true,
  "attr-lowercase": true,
  "attr-no-duplication": true,
  "attr-value-double-quotes": true,
  "attr-sorted": true,
