{
  "plugins": {

    "cssnano": {
      "preset": "default"
    },
    "postcss-preset-env": {
      "stage": 2
    },
    "postcss-import": {
      "path": "./src/Unprocessed-css"
    },
    "tailwindcss/nesting": {},
    "tailwindcss": {
      "config": "./tailwind.config.js"
    },
    "autoprefixer": {
      "grid": "autoplace",
      "cascade": true,
      "remove": false,
      "flexbox": "true",
      "add": true,
      "supports": true

    },
    "postcss-font-family-system-ui": {
      "fontFamily": {
        "base": "system-ui, sans-serif"
      }},
    "postcss-modules": {
      "generateScopedName": "[name]__[local]___[hash:base64:5]"
    }
  }
}