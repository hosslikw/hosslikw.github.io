{
 "plugins": {
  "postcss-import": {
    "path": "./src/Unprocessed-css"
  },
  "postcss-font-family-system-ui": {
    "fontFamily": {
      "base": "system-ui, sans-serif"
    }
  },

  "postcssColorMod": {
    "importFrom": [
      "./src/Unprocessed-css",
      "./src/base.css" ,
      {
        "customProperties": {
          "--brand-black" : "hsl(221%, 221%, 221%)"
          "--brand-white" : "hsl(221%, 221%, 221%)"

  },
  "postcss-preset-env": {
    "stage": 2
  },
  "tailwindcss/nesting": {},
  "tailwindcss": {
    "config": "./tailwind.config.js"
  },
  "autoprefixer": {
    "grid": "autoplace",
    "cascade": true,
    "remove": false,
    "flexbox": "true",
    "add": true,
    "supports": true
  },
  "postcss-modules": {
    "generateScopedName": "[name]__[local]___[hash:base64:5]"
  },
  "cssnano": {
    "preset": "default"
  }
 }
}
